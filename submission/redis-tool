def cmd_upgrade(args: argparse.Namespace, context: dict[str, object]) -> int:
    if args.strategy != "rolling":
        raise ToolError("Only --strategy rolling is implemented.")

    if check_all_nodes_version(args.target_version, context):
        print(f"All nodes are already running Redis {args.target_version}. No upgrade required.")
        return 0

    keys = get_keys_count(args)
    return ansible_playbook(
        "upgrade.yml",
        "upgrade",
        "upgrade_output.txt",
        {"target_version": args.target_version, "keys_count": keys},
    )


def cmd_rollback(args: argparse.Namespace, _context: dict[str, object]) -> int:
    keys = get_keys_count(args)
    rc = ansible_playbook(
        "rollback.yml",
        "rollback",
        "rollback_output.txt",
        {"target_version": args.target_version},
    )
