        "rollback_seed_output.txt",
        {"keys_count": keys},
    )
    return rc_seed


def cmd_verify(args: argparse.Namespace, _context: dict[str, object]) -> int:
    if not args.full:
        raise ToolError("Use --full for the comprehensive verification check.")
    keys = get_keys_count(args)
    return ansible_playbook(
        "verify_full.yml",
