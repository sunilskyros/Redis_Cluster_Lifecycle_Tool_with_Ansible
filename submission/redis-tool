AUTHORIZED_KEYS = SSH_DIR / "authorized_keys"
REDIS_CLI_PATH = "/opt/redis/current/bin/redis-cli"

MIN_ANSIBLE_VERSION = (2, 14, 0)


class ToolError(RuntimeError):
    """Raised for expected, user-facing command failures."""


def now_iso() -> str:
    return datetime.now(timezone.utc).isoformat(timespec="seconds")


def version_tuple(text: str) -> tuple[int, ...]:
    match = re.search(r"(\d+)\.(\d+)(?:\.(\d+))?", text)
    if not match:
        return ()
    return tuple(int(part) for part in match.groups(default="0"))


def run_capture(cmd: list[str], cwd: Path = PROJECT_ROOT) -> subprocess.CompletedProcess[str]:
    return subprocess.run(
        cmd,
        cwd=cwd,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        check=False,
    )


def print_missing_prereqs(messages: list[str]) -> None:
    for message in messages:
        print(message)
    print()
    print("Please install the missing dependencies and retry.")


def detect_container_runtime(runtime_override: str | None = None) -> dict[str, object] | None:
    """Detect the available container runtime (Podman preferred, then Docker).

    Uses *only* CLI invocation — no socket or REST API required.
    """
    target = runtime_override or os.environ.get("CONTAINER_RUNTIME", "").lower()

    if target:
        if target == "podman":
            if shutil.which("podman"):
                proc = run_capture(["podman", "--version"])
                return {"name": "podman", "cmd": ["podman"], "version": proc.stdout.strip()}
            return None
        if target == "docker":
            if shutil.which("docker"):
                proc = run_capture(["docker", "--version"])
                return {"name": "docker", "cmd": ["docker"], "version": proc.stdout.strip()}
            return None
        return None

    if shutil.which("podman"):
        proc = run_capture(["podman", "--version"])
        return {"name": "podman", "cmd": ["podman"], "version": proc.stdout.strip()}
    if shutil.which("docker"):
        proc = run_capture(["docker", "--version"])
        return {"name": "docker", "cmd": ["docker"], "version": proc.stdout.strip()}
    return None


def detect_compose(runtime: dict[str, object]) -> list[str] | None:
    """Detect the best compose command for the given runtime.

    Priority for Podman:
      1. ``podman-compose`` — pure Python CLI, works rootless with **no** socket.
      2. ``podman compose`` — Compose V2 plugin; requires the Podman REST API
         socket.  We probe it last and only after socket activation is attempted.

    Priority for Docker:
      1. ``docker compose`` — modern Compose V2 plugin (recommended).
      2. ``docker-compose`` — legacy standalone binary.
    """
    name = runtime["name"]
    if name == "podman":
        # Prefer podman-compose: it is a pure CLI wrapper that does NOT need the
        # Podman REST-API socket, making it safe on fresh / rootless systems.
        if shutil.which("podman-compose"):
            return ["podman-compose"]
        # Fall back to the Compose V2 plugin.  This communicates via the Podman
        # REST API socket, so we attempt automatic socket activation first.
        if _try_ensure_podman_socket():
            proc = run_capture(["podman", "compose", "version"])
            if proc.returncode == 0:
                return ["podman", "compose"]
        return None

    # Docker path
    proc = run_capture(["docker", "compose", "version"])
    if proc.returncode == 0:
        return ["docker", "compose"]
    if shutil.which("docker-compose"):
        return ["docker-compose"]
    return None


# ---------------------------------------------------------------------------
# Podman socket helpers
# ---------------------------------------------------------------------------

def _podman_socket_path() -> Optional[Path]:
    """Return the expected user-level Podman REST API socket path, or None."""
    xdg = os.environ.get("XDG_RUNTIME_DIR")
    if xdg:
        p = Path(xdg) / "podman" / "podman.sock"
        if p.exists():
            return p
    uid = os.getuid()
    fallback = Path(f"/run/user/{uid}/podman/podman.sock")
    if fallback.exists():
        return fallback
    return None


def _systemctl_user_available() -> bool:
    """Return True when the calling process can reach a user systemd session."""
    proc = run_capture(["systemctl", "--user", "is-system-running"])
    # Acceptable states: running, degraded.  We just need *some* user session.
    return proc.returncode in (0, 1) or proc.stdout.strip() in (
        "running", "degraded", "starting"
    )


def _try_ensure_podman_socket() -> bool:
    """Attempt to activate podman.socket and return True on success.

    Strategy (no side-effects if the socket is already active):
    1. If the socket file already exists, return True immediately.
    2. Try ``systemctl --user start podman.socket``.
    3. Wait up to 5 s for the socket file to appear.
    4. If systemd is not available or the socket still does not exist, return
       False so the caller can produce a clear, actionable error message.
    """
    if _podman_socket_path() is not None:
        return True

    if not shutil.which("systemctl"):
        return False

    if not _systemctl_user_available():
        return False

    print("[INFO] Podman socket is not active — attempting automatic activation via systemd...")
    proc = run_capture(["systemctl", "--user", "start", "podman.socket"])
    if proc.returncode != 0:
        # Try enable + start as a fallback (first-time setup)
        run_capture(["systemctl", "--user", "enable", "podman.socket"])
        proc = run_capture(["systemctl", "--user", "start", "podman.socket"])
        if proc.returncode != 0:
            return False

    # Wait for the socket file to materialise (up to 5 s)
    for _ in range(10):
        if _podman_socket_path() is not None:
            print("[OK] Podman socket activated successfully.")
            return True
        time.sleep(0.5)

    return False


def ensure_podman_socket() -> None:
    """Activate podman.socket or raise ToolError with clear instructions."""
    if _try_ensure_podman_socket():
        return
    raise ToolError(
        "The 'podman compose' plugin requires the Podman REST API socket, "
        "but the socket could not be activated automatically.\n"
        "\n"
        "To fix this manually, run:\n"
        "  systemctl --user enable --now podman.socket\n"
        "\n"
        "Alternatively, install podman-compose (no socket needed):\n"
        "  pip install podman-compose\n"
        "  # or: dnf/apt install podman-compose\n"
        "\n"
        "Or switch to Docker:\n"
        "  ./redis-tool --runtime docker infra up"
    )


