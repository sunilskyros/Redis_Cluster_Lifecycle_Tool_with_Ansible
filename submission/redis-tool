        {"keys_count": keys},
    )


def add_common_key_arg(parser: argparse.ArgumentParser) -> None:
    parser.add_argument("--keys", type=int, default=None, help="Number of deterministic keys (default: last seeded count, or 1000)")


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="redis-tool",
        description="Provision, operate, verify, and upgrade a six-node Redis Cluster with Ansible.",
    )
    parser.add_argument(
        "--runtime",
        choices=["docker", "podman"],
        help="Force container runtime (docker or podman). Overrides auto-detection.",
    )
    subparsers = parser.add_subparsers(dest="command", required=True)

    infra = subparsers.add_parser("infra", help="Manage the local SSH container infrastructure")
    infra_sub = infra.add_subparsers(dest="infra_action", required=True)
    infra_sub.add_parser("up", help="Create SSH key, build images, and start containers").set_defaults(func=cmd_infra)
    infra_sub.add_parser("down", help="Stop and remove containers").set_defaults(func=cmd_infra)

    provision = subparsers.add_parser("provision", help="Install Redis and form the cluster")
    provision.add_argument("--version", required=True, help="Exact Redis version to install, for example 7.0.15")
    provision.add_argument("--masters", type=int, required=True, help="Number of Redis masters")
    provision.add_argument("--replicas-per-master", type=int, required=True, help="Replica count per master")
    provision.set_defaults(func=cmd_provision)

    data = subparsers.add_parser("data", help="Seed or verify deterministic test data")
    data_sub = data.add_subparsers(dest="data_action", required=True)
    seed = data_sub.add_parser("seed", help="Seed deterministic key/value pairs")
    add_common_key_arg(seed)
    seed.set_defaults(func=cmd_data_seed)
    verify = data_sub.add_parser("verify", help="Verify deterministic key/value pairs")
    add_common_key_arg(verify)
    verify.set_defaults(func=cmd_data_verify)

    status = subparsers.add_parser("status", help="Print Redis Cluster topology and health")
    status.set_defaults(func=cmd_status)

    upgrade = subparsers.add_parser("upgrade", help="Perform a zero-downtime rolling Redis upgrade")
    upgrade.add_argument("--target-version", required=True, help="Exact Redis version to upgrade to")
    upgrade.add_argument("--strategy", default="rolling", choices=["rolling"], help="Upgrade strategy")
    add_common_key_arg(upgrade)
    upgrade.set_defaults(func=cmd_upgrade)

    verify_full = subparsers.add_parser("verify", help="Run full post-upgrade verification")
    verify_full.add_argument("--full", action="store_true", required=True, help="Run all verification checks")
    add_common_key_arg(verify_full)
    verify_full.set_defaults(func=cmd_verify)

    rollback = subparsers.add_parser("rollback", help="Roll back upgraded nodes to a previous version")
    rollback.add_argument("--target-version", required=True, help="Target version to roll back to")
    add_common_key_arg(rollback)
    rollback.set_defaults(func=cmd_rollback)

    scale = subparsers.add_parser("scale", help="Scale the Redis Cluster out or in")
    scale_group = scale.add_mutually_exclusive_group(required=True)
