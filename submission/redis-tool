    scale_group.add_argument("--remove-node", type=str, help="Node ID of the master (or replica) to remove")
    scale.set_defaults(func=cmd_scale)

    return parser


def is_infra_running(context: dict[str, object]) -> bool:
    """Return True when all expected containers are running.

    Uses only ``<runtime> ps`` CLI, which works without the Podman REST API
    socket (rootless Podman supports ``podman ps`` directly).
    """
    runtime = context["runtime"]
    assert isinstance(runtime, dict)
    cmd = list(runtime["cmd"])
    try:
        proc = run_capture(cmd + [
            "ps",
            "--filter", "label=com.docker.compose.project=infra",
            "--filter", "status=running",
            "-q",
        ])
        if proc.returncode != 0:
            # The filter approach can fail on older Podman versions; fall back to
            # checking each container by name.
            return _is_infra_running_by_name(cmd)
        running = [line.strip() for line in proc.stdout.splitlines() if line.strip()]
        expected = len(parse_inventory())
        if len(running) >= expected and expected > 0:
            return True
        # Label filter may return 0 even when containers exist (older Podman/compose
        # versions may not set compose labels).  Fall back to name-based check.
        return _is_infra_running_by_name(cmd)
    except Exception:
        return False


def _is_infra_running_by_name(runtime_cmd: list[str]) -> bool:
    """Fallback: check containers listed in the inventory are running by name."""
    nodes = parse_inventory()
    if not nodes:
        return False
    running_count = 0
    for node in nodes:
        name = node["name"]
        proc = run_capture(runtime_cmd + ["inspect", "--format", "{{.State.Running}}", name])
        if proc.returncode == 0 and proc.stdout.strip().lower() == "true":
            running_count += 1
    return running_count >= len(nodes)


def main(argv: Iterable[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    try:
        context = check_prereqs(runtime_override=getattr(args, "runtime", None))
        if args.command in ("provision", "data", "status", "upgrade", "verify", "scale", "rollback"):
            if not is_infra_running(context):
                infra_args = argparse.Namespace(infra_action="up")
                rc = cmd_infra(infra_args, context)
                if rc != 0:
                    return rc
                time.sleep(2)
        return args.func(args, context)
    except ToolError as exc:
        print(f"ERROR: {exc}", file=sys.stderr)
        return 2
    except KeyboardInterrupt:
        print("Interrupted", file=sys.stderr)
        return 130


